*.exe
*.obj
*.o
*.pdb
*.ilk
*.lib
*.dll
*.exp

# ===== Generated C from the M1 compiler =====
*_gen.c
*_out.c
tests/generated_c/

# ===== Debug session dumps =====
_m1_*.txt
_m1c_*.txt
_out.txt
out.txt
*_err.txt
*_err[0-9].txt
*stderr*.txt
*stdout*.txt
tests/debug_logs/

# ===== Injected test sources (generated at test time) =====
src/m1/_inj_*.m1

# ===== Stderr capture files =====
*.stderr

# ===== Test runner scratch =====
tests/build/*
!tests/build/run_tests.ps1

