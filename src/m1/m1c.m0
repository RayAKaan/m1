    }

    fn emit_fn_ep(reg : Int, l : Int, first : Int) -> Int {
        if m0_is_nil(l) == 1 { 0 } else {
            let _psep : Int = if first == 0 { m0_print(", ") } else { 0 };
            let _p0 : Int = emit_c_type(reg, m0_get(m0_head(l), 1));
            let _p1 : Int = m0_print(" ");
            let _p2 : Int = m0_print(m0_load_string(m0_head(l), 0));
