    fn now_emit_rechecks(reg : Int, i : Int, n : Int) -> Int {
        if i >= n { 0 } else {
            let node : Int = pg_rc_get_node(i);
            let _c0 : Int = m0_print(", ({ if (!(");
            let _c1 : Int = emit_c_expr(reg, node);
            let _c2 : Int = m0_print(")) { fprintf(stderr, \"[M1100] now invariant violated at line ");
            let _c3 : Int = m0_print_int(m0_get(node, 1));
            let _c4 : Int = m0_print(", col ");
            let _c5 : Int = m0_print_int(m0_get(node, 2));
            let _c6 : Int = m0_print("\\n\"); } 0; })");
            now_emit_rechecks(reg, i + 1, n)
        }
    }

    fn emit_now_add_deps(cond : Int, vars : Int) -> Int {
        if m0_is_nil(vars) == 1 { 0 } else {
            let vnode : Int = m0_head(vars);
            let vn : String = m0_load_string(vnode, 3);
            let _d : Int = pg_add_dep(vn, cond);
            emit_now_add_deps(cond, m0_tail(vars))
        }
    }

    fn emit_now_rechecks_for_var(reg : Int, nm : String) -> Int {
        let cnt : Int = pg_rc_count_for_var(nm);
        emit_now_rechecks_for_var_loop(reg, nm, 0, cnt)
    }

    fn emit_now_rechecks_for_var_loop(reg : Int, nm : String, i : Int, n : Int) -> Int {
        if i >= n { 0 } else {
            let node : Int = pg_rc_get_node_for_var(nm, i);
