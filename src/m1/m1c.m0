    -- ========================================================
    -- PHASE 1: Temporal Lowering + Clean Emission
    -- ========================================================

    fn lower_temporal(reg : Int, node : Int) -> Int {
        let k : Int = m0_get(node, 0);
        if k == N_FREEZE {
            let nm : String = m0_load_string(node, 3);
            let _ : Int = pg_freeze(nm);
            node
        } else {
        if k == N_NOW {
            let cond : Int = m0_get(node, 3);
            let _cf : Int = register_constraint(cond, 0);
            let _rc : Int = pg_rc_declare(cond);
            let vars : Int = find_vars(cond, m0_nil);
            let _ad : Int = emit_now_add_deps(cond, vars);
            node
        } else {
        if k == N_WILL {
            let cond : Int = m0_get(node, 3);
            let _cf : Int = register_constraint(cond, 1);
            let _ : Int = pg_wg_declare(cond);
            node
        } else {
        if k == N_WAS {
            node
        } else {
        if k == N_WHEN {
            node
        } else {
            node
        }}}}}
    }

    fn lower_decl(reg : Int, d : Int) -> Int {
        let k : Int = m0_get(d, 0);
        if k == N_FN_DECL {
            let body : Int = m0_get(d, 6);
            let new_body : Int = lower_temporal(reg, body);
            let _ : Int = m0_set(d, 6, new_body);
            d
        } else {
            d
        }
    }
