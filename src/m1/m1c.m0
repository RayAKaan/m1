    fn register_constraint(cond : Int, kind : Int) -> Int {
        if m0_get(cond, 0) == N_BINARY {
            let op : Int = m0_get(cond, 3);
            let l : Int = m0_get(cond, 4);
            let r : Int = m0_get(cond, 5);
            if m0_get(l, 0) == N_NAME {
                if m0_get(r, 0) == N_INT {
                    pg_constraint(m0_load_string(l, 3), op, m0_get(r, 3), kind)
                } else { 0 }
            } else {
                if m0_get(r, 0) == N_NAME {
                    if m0_get(l, 0) == N_INT {
                        pg_constraint(m0_load_string(r, 3), flip_op(op), m0_get(l, 3), kind)
                    } else { 0 }
                } else { 0 }
            }
        } else { 0 }
    }

    fn flip_op(op : Int) -> Int {
        if op == OP_LT { OP_GT } else {
        if op == OP_GT { OP_LT } else {
        if op == OP_LE { OP_GE } else {
        if op == OP_GE { OP_LE } else {
        op }}}}
    }

