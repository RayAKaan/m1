module M1C {
    external "m0_read_file" : String -> String
    external "m0_print" : String -> Int
    external "m0_print_int" : Int -> Int
    external "m0_string_eq" : String -> String -> Int
    external "m0_get" : Int -> Int -> Int
    external "m0_load_string" : Int -> Int -> String
    external "m0_is_nil" : Int -> Int
    external "m0_head" : Int -> Int
    external "m0_tail" : Int -> Int
    external "m0_alloc" : Int -> Int
    external "m0_set" : Int -> Int -> Int -> Int
    external "m0_store_string" : Int -> Int -> String -> Int
    external "m0_cons" : Int -> Int -> Int
    external "m0_nil" : Int
    external "m0_list_length" : Int -> Int
    external "m0_get_env" : String -> String
    external "m0_int_to_string" : Int -> String

    external "phase_graph_init" : Unit -> Int
    external "phase_graph_record" : String -> String -> Int
    external "phase_graph_freeze" : String -> Int
    external "phase_graph_query" : String -> String -> Int
    external "phase_graph_will_check" : String -> String -> Int
    external "phase_graph_now_recheck_declare" : Int -> Int
    external "phase_graph_now_recheck_count" : Unit -> Int
    external "phase_graph_now_recheck_get_node" : Int -> Int
    external "phase_graph_will_guard_declare" : Int -> Int
    external "phase_graph_will_guard_count" : Unit -> Int
    external "phase_graph_will_guard_get_node" : Int -> Int
    external "phase_graph_constraint_check" : String -> Int -> Int -> Int -> Int
    external "phase_graph_enter_branch" : Unit -> Int
    external "phase_graph_exit_branch" : Unit -> Int

    fn pg_init() -> Int { phase_graph_init(()) }
    fn pg_record(v : String, p : String) -> Int { phase_graph_record(v, p) }
    fn pg_freeze(v : String) -> Int { phase_graph_freeze(v) }
    fn pg_query(v : String, p : String) -> Int { phase_graph_query(v, p) }
    fn pg_will_check(v : String, p : String) -> Int { phase_graph_will_check(v, p) }
    fn pg_rc_declare(cond : Int) -> Int { phase_graph_now_recheck_declare(cond) }
    fn pg_rc_count() -> Int { phase_graph_now_recheck_count(()) }
    fn pg_rc_get_node(i : Int) -> Int { phase_graph_now_recheck_get_node(i) }
    fn pg_wg_declare(cond : Int) -> Int { phase_graph_will_guard_declare(cond) }
    fn pg_wg_count() -> Int { phase_graph_will_guard_count(()) }
    fn pg_wg_get_node(i : Int) -> Int { phase_graph_will_guard_get_node(i) }
    fn pg_constraint(v : String, op : Int, val : Int, kind : Int) -> Int { phase_graph_constraint_check(v, op, val, kind) }
    fn pg_enter_branch() -> Int { phase_graph_enter_branch(()) }
    fn pg_exit_branch() -> Int { phase_graph_exit_branch(()) }

    type M1Token = { kind : Int, line : Int, col : Int, int_val : Int, str_val : String }
    type M1Lexer = { src : String, pos : Int, line : Int, col : Int }
    type M1LexResult = { token : M1Token, lexer : M1Lexer }
    external "m1_lexer_init" : String -> M1Lexer
    external "m1_lexer_next" : M1Lexer -> M1LexResult

    let TK_EOF : Int = 0
    let TK_INT : Int = 1
    let TK_STRING : Int = 3
    let TK_IDENT : Int = 5
    let TK_ARROW : Int = 6
    let TK_LARROW : Int = 7
    let TK_BIDI : Int = 8
    let TK_EQ : Int = 9
    let TK_EQEQ : Int = 10
    let TK_NEQ : Int = 11
    let TK_LT : Int = 12
    let TK_GT : Int = 13
    let TK_LE : Int = 14
    let TK_GE : Int = 15
    let TK_AND : Int = 16
    let TK_OR : Int = 17
    let TK_PIPE : Int = 18
    let TK_COLON : Int = 19
    let TK_COMMA : Int = 20
    let TK_DOT : Int = 21
    let TK_SEMI : Int = 22
    let TK_LBRACE : Int = 24
    let TK_RBRACE : Int = 25
    let TK_LPAREN : Int = 26
    let TK_RPAREN : Int = 27
    let TK_LBRACK : Int = 28
    let TK_RBRACK : Int = 29
    let TK_PLUS : Int = 30
    let TK_MINUS : Int = 31
    let TK_STAR : Int = 32
    let TK_SLASH : Int = 33
    let TK_PERCENT : Int = 34
    let TK_UNIT : Int = 35
    let TK_MODULE : Int = 36
    let TK_TYPE : Int = 37
    let TK_FN : Int = 38
    let TK_LET : Int = 39
    let TK_MATCH : Int = 40
    let TK_IF : Int = 41
    let TK_ELSE : Int = 42
    let TK_TRUE : Int = 43
    let TK_FALSE : Int = 44
    let TK_EXTERNAL : Int = 45
    let TK_NOT : Int = 46
    let TK_FORALL : Int = 47
    let TK_EXISTS : Int = 48
    let TK_MUT : Int = 49
    let TK_WHILE : Int = 50
    -- NOTE: these MUST match the M1Tk enum order in src/m1/lexer.c (the linked
    -- lexer). They were previously misaligned (live/freeze/now/then) which made
    -- temporal forms unparseable in the self-hosted path. Aligned 2026-06-14.
    let TK_FREEZE : Int = 51
    let TK_NOW : Int = 52
    let TK_WWAS : Int = 53
    let TK_WHEN : Int = 54
    let TK_WILL : Int = 55
    let TK_LIVE : Int = 61
    let TK_THEN : Int = 64
    -- Surface-syntax keywords (Week 2 F4): world/do/set/pick/shape/say/show.
    -- Values match the M1Tk enum order in lexer.m0 / lexer.c.
    let TK_WORLD : Int = 56
    let TK_DO : Int = 57
    let TK_SET : Int = 58
    let TK_PICK : Int = 59
    let TK_SHAPE : Int = 60
    let TK_SAY : Int = 62
    let TK_SHOW : Int = 63

    let N_PROG : Int = 0
    let N_MOD : Int = 1
    let N_TYPE_DECL : Int = 2
    let N_PROP_DECL : Int = 3
    let N_FN_DECL : Int = 4
    let N_EXTERN : Int = 5
    let N_INT : Int = 6
    let N_STRING : Int = 7
    let N_BOOL : Int = 8
    let N_UNIT : Int = 9
    let N_NAME : Int = 10
    let N_BINARY : Int = 11
    let N_NOT : Int = 12
    let N_FIELD : Int = 13
    let N_CALL : Int = 14
    let N_SEQ : Int = 15
    let N_LET : Int = 16
    let N_LAMBDA : Int = 17
    let N_MATCH : Int = 18
    let N_IF : Int = 19
    let N_RECORD : Int = 20
    let N_LIST : Int = 21
    let N_ASSIGN : Int = 22
    let N_WHILE : Int = 23
    let N_LIVE : Int = 24
    let N_FREEZE : Int = 25
    let N_WAS : Int = 26
    let N_WILL : Int = 27
    let N_NOW : Int = 28
    let N_WHEN : Int = 29
    let N_FOR : Int = 30
    let N_CONST_DECL : Int = 31

    let T_NAMED : Int = 100
    let T_FN : Int = 101
    let T_RECORD : Int = 102
    let T_SUM : Int = 103
    let T_APP : Int = 104

    let OP_ADD : Int = 0
    let OP_SUB : Int = 1
    let OP_MUL : Int = 2
    let OP_DIV : Int = 3
    let OP_MOD : Int = 4
    let OP_EQ : Int = 5
    let OP_NEQ : Int = 6
    let OP_LT : Int = 7
    let OP_GT : Int = 8
    let OP_LE : Int = 9
    let OP_GE : Int = 10
    let OP_AND : Int = 11
    let OP_OR : Int = 12
    let OP_IMPL : Int = 13
    let OP_IFF : Int = 14

    let P_WILD : Int = 0
    let P_LIT : Int = 1
    let P_CTOR : Int = 2
    let P_NAME : Int = 4

    type PS = { tk : M1Token, lx : M1Lexer, err : Int }
    type PR = { node : Int, st : PS }

    fn ps_kind(s : PS) -> Int { s.tk.kind }
    fn ps_line(s : PS) -> Int { s.tk.line }
    fn ps_col(s : PS) -> Int { s.tk.col }
    fn ps_str(s : PS) -> String { s.tk.str_val }
    fn ps_int(s : PS) -> Int { s.tk.int_val }
    fn ps_adv(s : PS) -> PS {
        let r : M1LexResult = m1_lexer_next(s.lx);
        { tk = r.token, lx = r.lexer, err = s.err }
    }
    fn ps_err(s : PS) -> PS { { tk = s.tk, lx = s.lx, err = s.err + 1 } }
    fn mk_pr(n : Int, s : PS) -> PR { { node = n, st = s } }

    fn nk(k : Int, line : Int, col : Int, sz : Int) -> Int {
        let n : Int = m0_alloc(sz);
        let s0 : Int = m0_set(n, 0, k);
        let s1 : Int = m0_set(n, 1, line);
        let s2 : Int = m0_set(n, 2, col);
        n
    }
    fn n_int(v : Int, line : Int, col : Int) -> Int {
        let n : Int = nk(N_INT, line, col, 4);
        let s : Int = m0_set(n, 3, v);
        n
    }
    fn n_str(v : String, line : Int, col : Int) -> Int {
        let n : Int = nk(N_STRING, line, col, 4);
        let s : Int = m0_store_string(n, 3, v);
        n
    }
    fn n_bool(v : Int, line : Int, col : Int) -> Int {
        let n : Int = nk(N_BOOL, line, col, 4);
        let s : Int = m0_set(n, 3, v);
        n
    }
    fn n_unit(line : Int, col : Int) -> Int { nk(N_UNIT, line, col, 3) }
    fn n_name(nm : String, line : Int, col : Int) -> Int {
        let n : Int = nk(N_NAME, line, col, 4);
        let s : Int = m0_store_string(n, 3, nm);
        n
    }
    fn n_bin(op : Int, l : Int, r : Int, line : Int, col : Int) -> Int {
        let n : Int = nk(N_BINARY, line, col, 6);
        let s0 : Int = m0_set(n, 3, op);
        let s1 : Int = m0_set(n, 4, l);
        let s2 : Int = m0_set(n, 5, r);
        n
    }
    fn n_not(e : Int, line : Int, col : Int) -> Int {
        let n : Int = nk(N_NOT, line, col, 4);
        let s : Int = m0_set(n, 3, e);
        n
    }
    fn n_field(e : Int, nm : String, line : Int, col : Int) -> Int {
        let n : Int = nk(N_FIELD, line, col, 5);
        let s0 : Int = m0_set(n, 3, e);
        let s1 : Int = m0_store_string(n, 4, nm);
        n
    }
    fn n_call(e : Int, args : Int, cnt : Int, line : Int, col : Int) -> Int {
        let n : Int = nk(N_CALL, line, col, 6);
        let s0 : Int = m0_set(n, 3, e);
        let s1 : Int = m0_set(n, 4, args);
        let s2 : Int = m0_set(n, 5, cnt);
        n
    }
    fn n_let(nm : String, ty : Int, v : Int, body : Int, line : Int, col : Int) -> Int {
        let n : Int = nk(N_LET, line, col, 7);
        let s0 : Int = m0_store_string(n, 3, nm);
        let s1 : Int = m0_set(n, 4, ty);
        let s2 : Int = m0_set(n, 5, v);
        let s3 : Int = m0_set(n, 6, body);
        n
    }
    fn n_match(sc : Int, arms : Int, cnt : Int, line : Int, col : Int) -> Int {
        let n : Int = nk(N_MATCH, line, col, 6);
        let s0 : Int = m0_set(n, 3, sc);
        let s1 : Int = m0_set(n, 4, arms);
        let s2 : Int = m0_set(n, 5, cnt);
        n
    }
    fn n_if(c : Int, t : Int, e : Int, line : Int, col : Int) -> Int {
        let n : Int = nk(N_IF, line, col, 6);
        let s0 : Int = m0_set(n, 3, c);
        let s1 : Int = m0_set(n, 4, t);
        let s2 : Int = m0_set(n, 5, e);
        n
    }
    fn n_record(fields : Int, cnt : Int, line : Int, col : Int) -> Int {
        let n : Int = nk(N_RECORD, line, col, 5);
        let s0 : Int = m0_set(n, 3, fields);
        let s1 : Int = m0_set(n, 4, cnt);
        n
    }
    fn n_assign(nm : String, v : Int, line : Int, col : Int) -> Int {
        let n : Int = nk(N_ASSIGN, line, col, 5);
        let s0 : Int = m0_store_string(n, 3, nm);
        let s1 : Int = m0_set(n, 4, v);
        n
    }
    fn n_while(cond : Int, body : Int, line : Int, col : Int) -> Int {
        let n : Int = nk(N_WHILE, line, col, 5);
        let s0 : Int = m0_set(n, 3, cond);
        let s1 : Int = m0_set(n, 4, body);
        n
    }
    fn n_live(nm : String, ty : Int, val : Int, body : Int, line : Int, col : Int) -> Int {
        let n : Int = nk(N_LIVE, line, col, 7);
        let s0 : Int = m0_store_string(n, 3, nm);
        let s1 : Int = m0_set(n, 4, ty);
        let s2 : Int = m0_set(n, 5, val);
        let s3 : Int = m0_set(n, 6, body);
        n
    }
    fn n_freeze(nm : String, line : Int, col : Int) -> Int {
        let n : Int = nk(N_FREEZE, line, col, 4);
        let s : Int = m0_store_string(n, 3, nm);
        n
    }
    fn n_was(var : Int, phase : String, line : Int, col : Int) -> Int {
        let n : Int = nk(N_WAS, line, col, 5);
        let s0 : Int = m0_set(n, 3, var);
        let s1 : Int = m0_store_string(n, 4, phase);
        n
    }
    fn n_will(cond : Int, line : Int, col : Int) -> Int {
        let n : Int = nk(N_WILL, line, col, 4);
        let s : Int = m0_set(n, 3, cond);
        n
    }
    fn n_now(cond : Int, line : Int, col : Int) -> Int {
        let n : Int = nk(N_NOW, line, col, 4);
        let s : Int = m0_set(n, 3, cond);
        n
    }
