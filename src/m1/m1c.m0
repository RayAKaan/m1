                let a1 : Int = find_vars(m0_get(node, 3), acc);
                let a2 : Int = find_vars(m0_get(node, 4), a1);
                find_vars(m0_get(node, 5), a2)
            } else {
            if k == N_NOW { find_vars(m0_get(node, 3), acc) } else {
            if k == N_WILL { find_vars(m0_get(node, 3), acc) } else {
            if k == N_WHEN {
