    fn pg_init() -> Int { phase_graph_init(()) }
    fn pg_record(v : String, p : String) -> Int { phase_graph_record(v, p) }
    fn pg_freeze(v : String) -> Int { phase_graph_freeze(v) }
    fn pg_query(v : String, p : String) -> Int { phase_graph_query(v, p) }
    fn pg_will_check(v : String, p : String) -> Int { phase_graph_will_check(v, p) }
    fn pg_rc_declare(cond : Int) -> Int { phase_graph_now_recheck_declare(cond) }
    fn pg_rc_count() -> Int { phase_graph_now_recheck_count(()) }
    fn pg_rc_get_node(i : Int) -> Int { phase_graph_now_recheck_get_node(i) }
    fn pg_wg_declare(cond : Int) -> Int { phase_graph_will_guard_declare(cond) }
    fn pg_wg_count() -> Int { phase_graph_will_guard_count(()) }
    fn pg_wg_get_node(i : Int) -> Int { phase_graph_will_guard_get_node(i) }
    fn pg_add_dep(v : String, n : Int) -> Int { phase_graph_add_dep(v, n) }
    fn pg_rc_count_for_var(v : String) -> Int { phase_graph_now_recheck_count_for_var(v) }
    fn pg_rc_get_node_for_var(v : String, i : Int) -> Int { phase_graph_now_recheck_get_node_for_var(v, i) }
    fn pg_intern_var(v : String) -> Int { phase_graph_intern_var(v) }
    fn pg_intern_phase(p : String) -> Int { phase_graph_intern_phase(p) }
    fn pg_constraint(v : String, op : Int, val : Int, kind : Int) -> Int { phase_graph_constraint_check(v, op, val, kind) }
    fn pg_enter_branch() -> Int { phase_graph_enter_branch(()) }
    fn pg_exit_branch() -> Int { phase_graph_exit_branch(()) }

    type M1Token = { kind : Int, line : Int, col : Int, int_val : Int, str_val : String }
    type M1Lexer = { src : String, pos : Int, line : Int, col : Int }
    type M1LexResult = { token : M1Token, lexer : M1Lexer }
    external "m1_lexer_init" : String -> M1Lexer
    external "m1_lexer_next" : M1Lexer -> M1LexResult

