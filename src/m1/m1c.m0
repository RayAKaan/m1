    }

    fn list_rev(l : Int, acc : Int) -> Int {
        if m0_is_nil(l) == 1 { acc } else { list_rev(m0_tail(l), m0_cons(m0_head(l), acc)) }
    }
    fn rev(l : Int) -> Int { list_rev(l, m0_nil) }
    fn list_len(l : Int) -> Int {
        if m0_is_nil(l) == 1 { 0 } else { 1 + list_len(m0_tail(l)) }
    }

    fn gather_type_fields(s : PS, acc : Int, line : Int, col : Int) -> PR {
        if ps_kind(s) == TK_RBRACE { mk_pr(t_record(rev(acc), list_len(acc), line, col), ps_adv(s)) } else {
            let nm : String = ps_str(s);
            let s2 : PS = ps_adv(ps_adv(s));
            let r : PR = parse_type_expr(s2);
            let f : Int = mk_fi(nm, r.node);
            let s3 : PS = if ps_kind(r.st) == TK_COMMA { ps_adv(r.st) } else { r.st };
            gather_type_fields(s3, m0_cons(f, acc), line, col)
        }
    }

    fn gather_ctors(s : PS, acc : Int, line : Int, col : Int) -> PR {
        let nm : String = ps_str(s);
        let s2 : PS = ps_adv(s);
        let arg_r : PR = if ps_kind(s2) == TK_LPAREN {
            let r : PR = parse_type_expr(ps_adv(s2));
            mk_pr(r.node, ps_adv(r.st))
        } else { mk_pr(0, s2) };
        let c : Int = mk_ctor(nm, arg_r.node);
        let acc2 : Int = m0_cons(c, acc);
        if ps_kind(arg_r.st) == TK_PIPE { gather_ctors(ps_adv(arg_r.st), acc2, line, col) }
        else { mk_pr(t_sum(rev(acc2), list_len(acc2), line, col), arg_r.st) }
    }

    fn parse_type_atom(s : PS) -> PR {
        let k : Int = ps_kind(s);
        let line : Int = ps_line(s);
        let col : Int = ps_col(s);
        if k == TK_INT { mk_pr(t_name(ps_str(s), line, col), ps_adv(s)) } else {
        if k == TK_IDENT { mk_pr(t_name(ps_str(s), line, col), ps_adv(s)) } else {
        if k == TK_LBRACE { gather_type_fields(ps_adv(s), m0_nil, line, col) } else {
        if k == TK_PIPE { gather_ctors(ps_adv(s), m0_nil, line, col) } else {
        if k == TK_LPAREN {
            let r : PR = parse_type_expr(ps_adv(s));
            mk_pr(r.node, ps_adv(r.st))
        } else { mk_pr(n_unit(line, col), ps_err(s)) }}}}}
    }

    fn parse_type_app_ga(base_node : Int, s : PS, acc : Int, line : Int, col : Int) -> PR {
        if ps_kind(s) == TK_RPAREN { mk_pr(t_app(base_node, rev(acc), list_len(acc), line, col), ps_adv(s)) } else {
            let ar : PR = parse_type_expr(s);
            let s2 : PS = if ps_kind(ar.st) == TK_COMMA { ps_adv(ar.st) } else { ar.st };
            parse_type_app_ga(base_node, s2, m0_cons(ar.node, acc), line, col)
        }
    }

    fn parse_type_app(s : PS) -> PR {
        let r : PR = parse_type_atom(s);
        if ps_kind(r.st) == TK_LPAREN {
            let line : Int = ps_line(r.st);
            let col : Int = ps_col(r.st);
            parse_type_app_ga(r.node, ps_adv(r.st), m0_nil, line, col)
        } else { r }
    }

    fn parse_type_arrow(s : PS) -> PR {
        let r : PR = parse_type_app(s);
        if ps_kind(r.st) == TK_ARROW {
            let r2 : PR = parse_type_arrow(ps_adv(r.st));
            mk_pr(t_fn(m0_cons(r.node, m0_nil), 1, r2.node, ps_line(r.st), ps_col(r.st)), r2.st)
        } else { r }
    }

    fn parse_type_expr(s : PS) -> PR { parse_type_arrow(s) }

    fn gather_params(s0 : PS, acc : Int) -> PR {
        let s : PS = if ps_kind(s0) == TK_LPAREN { ps_adv(s0) } else { s0 };
        if ps_kind(s) == TK_RPAREN { mk_pr(rev(acc), ps_adv(s)) } else {
        if ps_kind(s) == TK_UNIT { mk_pr(rev(acc), ps_adv(s)) } else {
            let nm : String = ps_str(s);
            let s2 : PS = ps_adv(ps_adv(s));
            let r : PR = parse_type_expr(s2);
            let p : Int = mk_param(nm, r.node);
            let s3 : PS = if ps_kind(r.st) == TK_COMMA { ps_adv(r.st) } else { r.st };
            gather_params(s3, m0_cons(p, acc))
        }}
    }

    fn parse_pat_atom(s : PS) -> PR {
        let k : Int = ps_kind(s);
        let line : Int = ps_line(s);
        let col : Int = ps_col(s);
        if k == TK_INT { mk_pr(p_lit(n_int(ps_int(s), line, col), line, col), ps_adv(s)) } else {
        if k == TK_TRUE { mk_pr(p_lit(n_bool(1, line, col), line, col), ps_adv(s)) } else {
        if k == TK_FALSE { mk_pr(p_lit(n_bool(0, line, col), line, col), ps_adv(s)) } else {
        if k == TK_IDENT {
            let nm : String = ps_str(s);
            let s2 : PS = ps_adv(s);
            if m0_string_eq(nm, "_") == 1 { mk_pr(p_wild(line, col), s2) } else {
            if ps_kind(s2) == TK_LPAREN {
                let r : PR = parse_pat_atom(ps_adv(s2));
                mk_pr(p_ctor(nm, r.node, line, col), ps_adv(r.st))
            } else { mk_pr(p_name(nm, line, col), s2) }}
        } else { mk_pr(p_wild(line, col), ps_err(s)) }}}}
    }

    fn gather_args(s : PS, acc : Int) -> PR {
        if ps_kind(s) == TK_RPAREN { mk_pr(rev(acc), ps_adv(s)) } else {
        if ps_kind(s) == TK_UNIT {
            let s1 : PS = ps_adv(s);
            let s2 : PS = if ps_kind(s1) == TK_RPAREN { ps_adv(s1) } else { s1 };
            mk_pr(rev(acc), s2)
        } else {
            let r : PR = parse_impl(s);
            let s2 : PS = if ps_kind(r.st) == TK_COMMA { ps_adv(r.st) } else { r.st };
            gather_args(s2, m0_cons(r.node, acc))
        }}
    }

    fn parse_postfix_loop(n : Int, s : PS) -> PR {
        if ps_kind(s) == TK_DOT {
            let nm : String = ps_str(ps_adv(s));
            parse_postfix_loop(n_field(n, nm, ps_line(s), ps_col(s)), ps_adv(ps_adv(s)))
        } else {
        if ps_kind(s) == TK_LPAREN {
            let ar : PR = gather_args(ps_adv(s), m0_nil);
            parse_postfix_loop(n_call(n, ar.node, list_len(ar.node), ps_line(s), ps_col(s)), ar.st)
        } else {
        if ps_kind(s) == TK_UNIT {
            parse_postfix_loop(n_call(n, m0_nil, 0, ps_line(s), ps_col(s)), ps_adv(s))
        } else {
        if ps_kind(s) == TK_EQ {
            let nm : String = m0_load_string(n, 3);
            let vr : PR = parse_expr(ps_adv(s));
            mk_pr(n_assign(nm, vr.node, ps_line(s), ps_col(s)), vr.st)
        } else { mk_pr(n, s) }}}}
    }

    fn parse_postfix(s : PS) -> PR {
        let r : PR = parse_atom(s);
        parse_postfix_loop(r.node, r.st)
    }

    fn parse_unary(s : PS) -> PR {
        if ps_kind(s) == TK_NOT {
            let r : PR = parse_unary(ps_adv(s));
            mk_pr(n_not(r.node, ps_line(s), ps_col(s)), r.st)
        } else {
        if ps_kind(s) == TK_MINUS {
            let r : PR = parse_unary(ps_adv(s));
            mk_pr(n_bin(OP_SUB, n_int(0, ps_line(s), ps_col(s)), r.node, ps_line(s), ps_col(s)), r.st)
        } else {
        if ps_kind(s) == TK_MUST {
            let r : PR = parse_unary(ps_adv(s));
            mk_pr(n_call(n_name("__must", ps_line(s), ps_col(s)), m0_cons(r.node, m0_nil), 1, ps_line(s), ps_col(s)), r.st)
        } else {
        if ps_kind(s) == TK_FN_REF {
            let sub : PR = parse_atom(ps_adv(s));
            parse_postfix_loop(n_fn_ref(sub.node, ps_line(s), ps_col(s)), sub.st)
        } else { parse_postfix(s) }}}}
    }

    fn parse_mul_loop(l : Int, s : PS) -> PR {
        if ps_kind(s) == TK_STAR { let r2 : PR = parse_unary(ps_adv(s)); parse_mul_loop(n_bin(OP_MUL, l, r2.node, ps_line(s), ps_col(s)), r2.st) } else {
        if ps_kind(s) == TK_SLASH { let r2 : PR = parse_unary(ps_adv(s)); parse_mul_loop(n_bin(OP_DIV, l, r2.node, ps_line(s), ps_col(s)), r2.st) } else {
        if ps_kind(s) == TK_PERCENT { let r2 : PR = parse_unary(ps_adv(s)); parse_mul_loop(n_bin(OP_MOD, l, r2.node, ps_line(s), ps_col(s)), r2.st) } else {
        mk_pr(l, s) }}}
    }

    fn parse_mul(s : PS) -> PR {
        let r : PR = parse_unary(s);
        parse_mul_loop(r.node, r.st)
    }

    fn parse_add_loop(l : Int, s : PS) -> PR {
        if ps_kind(s) == TK_PLUS { let r2 : PR = parse_mul(ps_adv(s)); parse_add_loop(n_bin(OP_ADD, l, r2.node, ps_line(s), ps_col(s)), r2.st) } else {
        if ps_kind(s) == TK_MINUS { let r2 : PR = parse_mul(ps_adv(s)); parse_add_loop(n_bin(OP_SUB, l, r2.node, ps_line(s), ps_col(s)), r2.st) } else {
        mk_pr(l, s) }}
    }

    fn parse_add(s : PS) -> PR {
        let r : PR = parse_mul(s);
        parse_add_loop(r.node, r.st)
    }

    fn parse_cmp(s : PS) -> PR {
        let r : PR = parse_add(s);
        let k : Int = ps_kind(r.st);
        if k == TK_EQEQ { let r2 : PR = parse_add(ps_adv(r.st)); mk_pr(n_bin(OP_EQ, r.node, r2.node, ps_line(r.st), ps_col(r.st)), r2.st) } else {
        if k == TK_NEQ { let r2 : PR = parse_add(ps_adv(r.st)); mk_pr(n_bin(OP_NEQ, r.node, r2.node, ps_line(r.st), ps_col(r.st)), r2.st) } else {
        if k == TK_LT { let r2 : PR = parse_add(ps_adv(r.st)); mk_pr(n_bin(OP_LT, r.node, r2.node, ps_line(r.st), ps_col(r.st)), r2.st) } else {
        if k == TK_GT { let r2 : PR = parse_add(ps_adv(r.st)); mk_pr(n_bin(OP_GT, r.node, r2.node, ps_line(r.st), ps_col(r.st)), r2.st) } else {
        if k == TK_LE { let r2 : PR = parse_add(ps_adv(r.st)); mk_pr(n_bin(OP_LE, r.node, r2.node, ps_line(r.st), ps_col(r.st)), r2.st) } else {
        if k == TK_GE { let r2 : PR = parse_add(ps_adv(r.st)); mk_pr(n_bin(OP_GE, r.node, r2.node, ps_line(r.st), ps_col(r.st)), r2.st) } else {
        r }}}}}}
    }

    fn parse_and_loop(l : Int, s : PS) -> PR {
        if ps_kind(s) == TK_AND {
            let r2 : PR = parse_cmp(ps_adv(s));
            parse_and_loop(n_bin(OP_AND, l, r2.node, ps_line(s), ps_col(s)), r2.st)
        } else { mk_pr(l, s) }
    }

    fn parse_and(s : PS) -> PR {
        let r : PR = parse_cmp(s);
        parse_and_loop(r.node, r.st)
    }

    fn parse_or_loop(l : Int, s : PS) -> PR {
        if ps_kind(s) == TK_OR {
            let r2 : PR = parse_and(ps_adv(s));
            parse_or_loop(n_bin(OP_OR, l, r2.node, ps_line(s), ps_col(s)), r2.st)
        } else { mk_pr(l, s) }
    }

    fn parse_or(s : PS) -> PR {
        let r : PR = parse_and(s);
        parse_or_loop(r.node, r.st)
    }

    fn parse_impl(s : PS) -> PR {
        let r : PR = parse_or(s);
        if ps_kind(r.st) == TK_ARROW {
            let r2 : PR = parse_impl(ps_adv(r.st));
            mk_pr(n_bin(OP_IMPL, r.node, r2.node, ps_line(r.st), ps_col(r.st)), r2.st)
        } else { r }
    }

    fn parse_seq(s : PS) -> PR {
        let r : PR = parse_impl(s);
        if ps_kind(r.st) == TK_COMMA {
            let r2 : PR = parse_seq(ps_adv(r.st));
            mk_pr(n_seq(r.node, r2.node, ps_line(r.st), ps_col(r.st)), r2.st)
        } else { r }
    }

    fn parse_expr(s : PS) -> PR {
        if ps_kind(s) == TK_BIDI {
            let r1 : PR = parse_seq(ps_adv(s));
            if ps_kind(r1.st) == TK_BIDI {
                let r2 : PR = parse_seq(ps_adv(r1.st));
                mk_pr(n_bin(OP_IFF, r1.node, r2.node, ps_line(s), ps_col(s)), r2.st)
            } else { mk_pr(r1.node, ps_err(r1.st)) }
        } else { parse_seq(s) }
    }

    fn gather_arms(s : PS, acc : Int) -> PR {
        if ps_kind(s) == TK_RBRACE { mk_pr(rev(acc), ps_adv(s)) } else {
            let pr : PR = parse_pat_atom(s);
            let s2 : PS = ps_adv(pr.st);
            let br : PR = parse_expr(s2);
            let s3 : PS = if ps_kind(br.st) == TK_SEMI { ps_adv(br.st) } else { br.st };
            gather_arms(s3, m0_cons(mk_arm(pr.node, br.node), acc))
        }
    }

    fn gather_field_inits(s : PS, acc : Int, line : Int, col : Int) -> PR {
        if ps_kind(s) == TK_RBRACE { mk_pr(n_record(rev(acc), list_len(acc), line, col), ps_adv(s)) } else {
        if ps_kind(s) == TK_EOF { mk_pr(n_record(rev(acc), list_len(acc), line, col), ps_err(s)) } else {
            let nm : String = ps_str(s);
            let s2 : PS = ps_adv(ps_adv(s));
            let r : PR = parse_impl(s2);
            let s3 : PS = if ps_kind(r.st) == TK_COMMA { ps_adv(r.st) } else { r.st };
            gather_field_inits(s3, m0_cons(mk_fi(nm, r.node), acc), line, col)
        }}
    }

    fn gather_list_elems(s : PS, acc : Int) -> PR {
        if ps_kind(s) == TK_RBRACK { mk_pr(rev(acc), ps_adv(s)) } else {
            let r : PR = parse_impl(s);
            let s2 : PS = if ps_kind(r.st) == TK_COMMA { ps_adv(r.st) } else { r.st };
            gather_list_elems(s2, m0_cons(r.node, acc))
        }
    }

    -- String interpolation with $"...{expr}..." syntax reserved for future use.

    fn parse_atom(s : PS) -> PR {
        let k : Int = ps_kind(s);
        let line : Int = ps_line(s);
        let col : Int = ps_col(s);
        if k == TK_INT { mk_pr(n_int(ps_int(s), line, col), ps_adv(s)) } else {
        if k == TK_STRING {
            let sv : String = ps_str(s);
            mk_pr(n_str(sv, line, col), ps_adv(s))
        } else {
        if k == TK_TRUE { mk_pr(n_bool(1, line, col), ps_adv(s)) } else {
        if k == TK_FALSE { mk_pr(n_bool(0, line, col), ps_adv(s)) } else {
        if k == TK_UNIT { mk_pr(n_unit(line, col), ps_adv(s)) } else {
        if k == TK_PANIC {
            let r : PR = parse_expr(ps_adv(s));
            mk_pr(n_call(n_name("panic", line, col), m0_cons(r.node, m0_nil), 1, line, col), r.st)
        } else {
        if k == TK_IDENT { mk_pr(n_name(ps_str(s), line, col), ps_adv(s)) } else {
        if k == TK_LET {
            let s_after_let : PS = ps_adv(s);
            let is_live : Int = if ps_kind(s_after_let) == TK_LIVE { 1 } else { 0 };
            let is_mut : Int = if m0_string_eq(ps_str(s_after_let), "mut") == 1 { 1 } else { 0 };
            let nm_ps : PS = if is_live == 1 { ps_adv(s_after_let) } else {
                              if is_mut == 1 { ps_adv(s_after_let) } else { s_after_let } };
            let nm : String = ps_str(nm_ps);
            let s_after_name : PS = ps_adv(nm_ps);
            let tr : PR = if ps_kind(s_after_name) == TK_COLON {
                parse_type_expr(ps_adv(s_after_name))
            } else {
                mk_pr(n_unit(ps_line(s_after_name), ps_col(s_after_name)), s_after_name)
            };
            let s_after_type : PS = if ps_kind(s_after_name) == TK_COLON {
                ps_adv(tr.st)
            } else {
                ps_adv(s_after_name)
            };
            let vr : PR = parse_expr(s_after_type);
            let s_after_val : PS = ps_adv(vr.st);
            let br : PR = parse_expr(s_after_val);
            if is_live == 1 {
                mk_pr(n_live(nm, tr.node, vr.node, br.node, line, col), br.st)
            } else {
                mk_pr(n_let(nm, tr.node, vr.node, br.node, line, col), br.st)
            }
        } else {
        if k == TK_SET {
            let s_after_set : PS = ps_adv(s);
            let is_live : Int = if ps_kind(s_after_set) == TK_LIVE { 1 } else { 0 };
            let nm_ps : PS = if is_live == 1 { ps_adv(s_after_set) } else { s_after_set };
            let nm : String = ps_str(nm_ps);
            let s_after_name : PS = ps_adv(nm_ps);
            let tr : PR = if ps_kind(s_after_name) == TK_COLON {
                parse_type_expr(ps_adv(s_after_name))
            } else {
                mk_pr(n_unit(ps_line(s_after_name), ps_col(s_after_name)), s_after_name)
            };
            let s_after_type : PS = if ps_kind(s_after_name) == TK_COLON {
                ps_adv(tr.st)
            } else {
                ps_adv(s_after_name)
            };
            let vr : PR = parse_expr(s_after_type);
            let s_after_val : PS = ps_adv(vr.st);
            let br : PR = parse_expr(s_after_val);
            if is_live == 1 {
                mk_pr(n_live(nm, tr.node, vr.node, br.node, line, col), br.st)
            } else {
                mk_pr(n_let(nm, tr.node, vr.node, br.node, line, col), br.st)
            }
        } else {
        if k == TK_SAY {
            let r : PR = parse_expr(ps_adv(ps_adv(s)));
            let s2 : PS = ps_adv(r.st);
            let arg_node : Int = if m0_get(r.node, 0) == N_INT {
                n_call(n_name("m0_int_to_string", line, col), m0_cons(r.node, m0_nil), 1, line, col)
            } else {
                r.node
            };
            mk_pr(n_call(n_name("m0_println", line, col), m0_cons(arg_node, m0_nil), 1, line, col), s2)
        } else {
        if k == TK_SHOW {
            let r : PR = parse_expr(ps_adv(ps_adv(s)));
            let s2 : PS = ps_adv(r.st);
            mk_pr(n_call(n_name("m0_print", line, col), m0_cons(r.node, m0_nil), 1, line, col), s2)
        } else {
        if k == TK_MATCH {
            let sr : PR = parse_expr(ps_adv(s));
            let ar : PR = gather_arms(ps_adv(sr.st), m0_nil);
            mk_pr(n_match(sr.node, ar.node, list_len(ar.node), line, col), ar.st)
        } else {
        if k == TK_PICK {
            let sr : PR = parse_expr(ps_adv(s));
            let ar : PR = gather_arms(ps_adv(sr.st), m0_nil);
            mk_pr(n_pick(sr.node, ar.node, list_len(ar.node), line, col), ar.st)
        } else {
        if k == TK_IF {
            let cr : PR = parse_expr(ps_adv(s));
            let tr : PR = parse_expr(cr.st);
            let s3 : PS = tr.st;
            let er : PR = if ps_kind(s3) == TK_ELSE {
                parse_expr(ps_adv(s3))
            } else { mk_pr(n_unit(line, col), s3) };
            mk_pr(n_if(cr.node, tr.node, er.node, line, col), er.st)
        } else {
        if k == TK_WHILE {
            let cr : PR = parse_expr(ps_adv(s));
            let br : PR = parse_expr(cr.st);
            mk_pr(n_while(cr.node, br.node, line, col), br.st)
        } else {
        if k == TK_FREEZE {
            let nm : String = ps_str(ps_adv(s));
            mk_pr(n_freeze(nm, line, col), ps_adv(ps_adv(s)))
        } else {
        if k == TK_WWAS {
            let vr : PR = parse_atom(ps_adv(s));
            let s_phase : PS = ps_adv(vr.st);
            let ph : String = if ps_kind(s_phase) == TK_INT {
                m0_int_to_string(ps_int(s_phase))
            } else {
                ps_str(s_phase)
            };
            mk_pr(n_was(vr.node, ph, line, col), ps_adv(s_phase))
        } else {
        if k == TK_WILL {
            let cr : PR = parse_expr(ps_adv(s));
            mk_pr(n_will(cr.node, line, col), cr.st)
        } else {
        if k == TK_NOW {
            let cr : PR = parse_expr(ps_adv(s));
            mk_pr(n_now(cr.node, line, col), cr.st)
        } else {
        if k == TK_WHEN {
            let cr : PR = parse_expr(ps_adv(s));
            let s2 : PS = ps_adv(cr.st);
            let br : PR = parse_expr(s2);
            mk_pr(n_when(cr.node, br.node, line, col), br.st)
        } else {
        if k == TK_LIVE {
            let s_after_live : PS = ps_adv(s);
            let nm : String = ps_str(s_after_live);
            let s_after_name : PS = ps_adv(s_after_live);
            let s_after_colon : PS = ps_adv(s_after_name);
            let tr : PR = parse_type_expr(s_after_colon);
            let s_after_type : PS = ps_adv(tr.st);
            let vr : PR = parse_expr(s_after_type);
            let s_after_val : PS = ps_adv(vr.st);
            let br : PR = parse_expr(s_after_val);
            mk_pr(n_live(nm, tr.node, vr.node, br.node, line, col), br.st)
        } else {
        if k == TK_LBRACE {
            let s_in : PS = ps_adv(s);
            let looks_field : Int = if ps_kind(s_in) == TK_IDENT {
                if ps_kind(ps_adv(s_in)) == TK_EQ { 1 } else { 0 }
            } else { 0 };
            if looks_field == 1 {
                let nm : String = ps_str(s_in);
                let s_val : PS = ps_adv(ps_adv(s_in));
                let vr : PR = parse_impl(s_val);
                if ps_kind(vr.st) == TK_COMMA {
                    gather_field_inits(ps_adv(vr.st), m0_cons(mk_fi(nm, vr.node), m0_nil), line, col)
                } else {
                    let blk : Int = n_assign(nm, vr.node, line, col);
                    mk_pr(blk, ps_adv(vr.st))
                }
            } else {
                let br : PR = parse_expr(s_in);
                mk_pr(br.node, ps_adv(br.st))
            }
        } else {
        if k == TK_LBRACK { gather_list_elems(ps_adv(s), m0_nil) } else {
        if k == TK_LPAREN {
            let r : PR = parse_expr(ps_adv(s));
            mk_pr(r.node, ps_adv(r.st))
        } else {
            mk_pr(n_unit(line, col), ps_err(s))
        }}}}}}}}}}}}}}}}}}}}}}}}
    }

    fn is_expr_start(k : Int) -> Int {
        if k == TK_INT { 1 } else {
        if k == TK_STRING { 1 } else {
        if k == TK_IDENT { 1 } else {
        if k == TK_LPAREN { 1 } else {
        if k == TK_LBRACE { 1 } else {
        if k == TK_IF { 1 } else {
        if k == TK_WHILE { 1 } else {
        if k == TK_MATCH { 1 } else {
        if k == TK_PICK { 1 } else {
        if k == TK_SAY { 1 } else {
        if k == TK_SHOW { 1 } else {
        if k == TK_FREEZE { 1 } else {
        if k == TK_WWAS { 1 } else {
        if k == TK_WILL { 1 } else {
        if k == TK_NOW { 1 } else {
        if k == TK_WHEN { 1 } else {
        if k == TK_NOT { 1 } else {
        if k == TK_MINUS { 1 } else {
        if k == TK_TRUE { 1 } else {
        if k == TK_FALSE { 1 } else {
        if k == TK_UNIT { 1 } else {
        if k == TK_FN_REF { 1 } else {
        if k == TK_PANIC { 1 } else {
        if k == TK_MUST { 1 } else { 0 }}}}}}}}}}}}}}}}}}}}}}}}
    }

    fn parse_decl(s : PS) -> PR {
        let k : Int = ps_kind(s);
        let line : Int = ps_line(s);
        let col : Int = ps_col(s);
        if k == TK_TYPE {
            let nm : String = ps_str(ps_adv(s));
            let s2 : PS = ps_adv(ps_adv(ps_adv(s)));
            let tr : PR = parse_type_expr(s2);
            mk_pr(n_type_decl(nm, tr.node, line, col), tr.st)
        } else {
        if k == TK_SHAPE {
            let nm : String = ps_str(ps_adv(s));
            let s2 : PS = ps_adv(ps_adv(ps_adv(s)));
            let tr : PR = parse_type_expr(s2);
            mk_pr(n_shape(nm, m0_get(tr.node, 3), m0_get(tr.node, 4), line, col), tr.st)
        } else {
        if k == TK_FN {
            let nm : String = ps_str(ps_adv(s));
            let pr : PR = gather_params(ps_adv(ps_adv(s)), m0_nil);
            let s2 : PS = ps_adv(pr.st);
            let rr : PR = parse_type_expr(s2);
            let s3 : PS = rr.st;
            let req_r : PR = if ps_kind(s3) == TK_REQUIRES {
                parse_expr(ps_adv(s3))
            } else { mk_pr(0, s3) };
            let s4 : PS = req_r.st;
            let ens_r : PR = if ps_kind(s4) == TK_ENSURES {
                parse_expr(ps_adv(s4))
            } else { mk_pr(0, s4) };
            let s5 : PS = ens_r.st;
            let br : PR = if ps_kind(s5) == TK_LBRACE {
                parse_expr(ps_adv(s5))
            } else { parse_expr(s5) };
            let s6 : PS = ps_adv(br.st);
            mk_pr(n_fn_decl(nm, pr.node, list_len(pr.node), rr.node, br.node, line, col, req_r.node, ens_r.node), s6)
        } else {
        if k == TK_DO {
            let nm : String = ps_str(ps_adv(s));
            let pr : PR = gather_params(ps_adv(ps_adv(s)), m0_nil);
            let s2 : PS = ps_adv(pr.st);
            let rr : PR = parse_type_expr(s2);
            let s3 : PS = rr.st;
            let req_r : PR = if ps_kind(s3) == TK_REQUIRES {
                parse_expr(ps_adv(s3))
            } else { mk_pr(0, s3) };
            let s4 : PS = req_r.st;
            let ens_r : PR = if ps_kind(s4) == TK_ENSURES {
                parse_expr(ps_adv(s4))
            } else { mk_pr(0, s4) };
            let s5 : PS = ens_r.st;
            let br : PR = if ps_kind(s5) == TK_LBRACE {
                parse_expr(ps_adv(s5))
            } else { parse_expr(s5) };
            let s6 : PS = ps_adv(br.st);
            mk_pr(n_fn_decl(nm, pr.node, list_len(pr.node), rr.node, br.node, line, col, req_r.node, ens_r.node), s6)
        } else {
        if k == TK_EXTERNAL {
            let cn : String = ps_str(ps_adv(s));
            let s2 : PS = ps_adv(ps_adv(ps_adv(s)));
            let tr : PR = parse_type_expr(s2);
            mk_pr(n_extern(cn, tr.node, line, col), tr.st)
        } else {
        if k == TK_LET {
            let nm : String = ps_str(ps_adv(s));
            let s_after_name : PS = ps_adv(ps_adv(s));
            let s_after_colon : PS = ps_adv(s_after_name);
            let tr : PR = parse_type_expr(s_after_colon);
            let s_after_type : PS = ps_adv(tr.st);
            let vr : PR = parse_expr(s_after_type);
            mk_pr(n_const_decl(nm, vr.node, line, col), vr.st)
        } else {
        if is_expr_start(k) == 1 {
            let er : PR = parse_expr(s);
            let s2 : PS = if ps_kind(er.st) == TK_SEMI { ps_adv(er.st) } else { er.st };
            mk_pr(n_let("_", t_name("Int", line, col), er.node, n_unit(line, col), line, col), s2)
        } else {
            mk_pr(n_unit(line, col), ps_err(ps_adv(s)))
        }}}}}}}
    }

    fn gather_decls(s : PS, acc : Int) -> PR {
        if ps_kind(s) == TK_RBRACE { mk_pr(rev(acc), ps_adv(s)) } else {
        if ps_kind(s) == TK_EOF { mk_pr(rev(acc), ps_err(s)) } else {
            let r : PR = parse_decl(s);
            gather_decls(r.st, m0_cons(r.node, acc))
        }}
    }

    fn parse_module(s : PS) -> PR {
        let line : Int = ps_line(s);
        let col : Int = ps_col(s);
        let nm : String = ps_str(ps_adv(s));
        let s2 : PS = ps_adv(ps_adv(ps_adv(s)));
        let dr : PR = gather_decls(s2, m0_nil);
        mk_pr(n_mod(nm, dr.node, list_len(dr.node), line, col), dr.st)
    }

    fn gather_modules(s : PS, acc : Int) -> PR {
        let k : Int = ps_kind(s);
        if k == TK_EOF { mk_pr(rev(acc), s) } else {
            if k == TK_MODULE {
                let r : PR = parse_module(s);
                gather_modules(r.st, m0_cons(r.node, acc))
            } else {
            if k == TK_WORLD {
                let r : PR = parse_module(s);
                gather_modules(r.st, m0_cons(r.node, acc))
            } else { mk_pr(rev(acc), ps_err(s)) }}
        }
    }

    fn parse_program(s : PS) -> PR {
        let r : PR = gather_modules(s, m0_nil);
        mk_pr(n_prog(r.node, list_len(r.node), ps_line(s), ps_col(s)), r.st)
    }

    -- ============================================================
    -- Codegen
    -- ============================================================

    fn reg_entry(name : String, t : Int, fields : Int, fn_ast : Int) -> Int {
        let e : Int = m0_alloc(4);
        let s0 : Int = m0_store_string(e, 0, name);
        let s1 : Int = m0_set(e, 1, t);
        let s2 : Int = m0_set(e, 2, fields);
        let s3 : Int = m0_set(e, 3, fn_ast);
        e
    }
    fn reg_name(e : Int) -> String { m0_load_string(e, 0) }
    fn reg_type(e : Int) -> Int { m0_get(e, 1) }
    fn reg_fields(e : Int) -> Int { m0_get(e, 2) }
    fn reg_fn_ast(e : Int) -> Int { m0_get(e, 3) }

    fn lookup_reg(reg : Int, name : String) -> Int {
        if m0_is_nil(reg) == 1 { 0 } else {
            if m0_string_eq(reg_name(m0_head(reg)), name) == 1 {
                m0_head(reg)
            } else { lookup_reg(m0_tail(reg), name) }
        }
    }

    fn fields_have(fields : Int, fname : String) -> Int {
        if m0_is_nil(fields) == 1 { 0 } else {
            if m0_string_eq(m0_load_string(m0_head(fields), 0), fname) == 1 { 1 }
            else { fields_have(m0_tail(fields), fname) }
        }
    }

    fn lookup_type_by_field(reg : Int, fname : String) -> String {
        if m0_is_nil(reg) == 1 { "" } else {
            if fields_have(reg_fields(m0_head(reg)), fname) == 1 {
                reg_name(m0_head(reg))
            } else { lookup_type_by_field(m0_tail(reg), fname) }
        }
    }

    fn find_ctor_index(ctors : Int, name : String, i : Int) -> Int {
        if m0_is_nil(ctors) == 1 { -1 } else {
            if m0_string_eq(m0_load_string(m0_head(ctors), 0), name) == 1 { i }
            else { find_ctor_index(m0_tail(ctors), name, i + 1) }
        }
    }

    fn lookup_ctor_info(reg : Int, ctor_name : String) -> Int {
        if m0_is_nil(reg) == 1 { 0 } else {
            let entry : Int = m0_head(reg);
            let t : Int = reg_type(entry);
            if m0_get(t, 0) == T_SUM {
                let ctors : Int = m0_get(t, 3);
                let idx : Int = find_ctor_index(ctors, ctor_name, 0);
                if idx >= 0 {
                    let info : Int = m0_alloc(3);
                    let _s0 : Int = m0_store_string(info, 0, reg_name(entry));
                    let _s1 : Int = m0_store_string(info, 1, ctor_name);
                    let _s2 : Int = m0_set(info, 2, idx);
                    info
                } else { lookup_ctor_info(m0_tail(reg), ctor_name) }
            } else { lookup_ctor_info(m0_tail(reg), ctor_name) }
        }
    }

    fn emit_enum_tags_body(reg : Int, l : Int, sname : String, i : Int) -> Int {
        if m0_is_nil(l) == 1 { m0_print(" };\n") } else {
            let _sep : Int = if i == 0 { m0_print("enum { ") } else { m0_print(", ") };
            let _p0 : Int = m0_print(sname);
            let _p1 : Int = m0_print("_");
            let _p2 : Int = m0_print(m0_load_string(m0_head(l), 0));
            let _p3 : Int = m0_print(" = ");
            let _p4 : Int = m0_print_int(i);
            emit_enum_tags_body(reg, m0_tail(l), sname, i + 1)
        }
    }

    fn emit_enum_tags(reg : Int, l : Int, sname : String) -> Int {
        emit_enum_tags_body(reg, l, sname, 0)
    }

    fn gather_param_types(params : Int, acc : Int) -> Int {
        if m0_is_nil(params) == 1 { rev(acc) } else {
            gather_param_types(m0_tail(params), m0_cons(m0_get(m0_head(params), 1), acc))
        }
    }

    fn build_reg(decls : Int, reg : Int) -> Int {
        if m0_is_nil(decls) == 1 { reg } else {
            let d : Int = m0_head(decls);
            if m0_get(d, 0) == N_TYPE_DECL {
                let nm : String = m0_load_string(d, 3);
                let t : Int = m0_get(d, 4);
                let fields : Int = if m0_get(t, 0) == T_RECORD {
                    m0_get(t, 3)
                } else { m0_nil };
                build_reg(m0_tail(decls), m0_cons(reg_entry(nm, t, fields, 0), reg))
            } else {
            if m0_get(d, 0) == N_SHAPE {
                let nm : String = m0_load_string(d, 3);
                let t : Int = t_sum(m0_get(d, 4), m0_get(d, 5), 0, 0);
                let fields : Int = m0_nil;
                build_reg(m0_tail(decls), m0_cons(reg_entry(nm, t, fields, 0), reg))
            } else {
            if m0_get(d, 0) == N_FN_DECL {
                let nm : String = m0_load_string(d, 3);
                let params : Int = m0_get(d, 4);
                let pc : Int = m0_get(d, 5);
                let ret : Int = m0_get(d, 6);
                let param_types : Int = gather_param_types(params, m0_nil);
                let t : Int = t_fn(param_types, pc, ret, 0, 0);
                build_reg(m0_tail(decls), m0_cons(reg_entry(nm, t, m0_nil, d), reg))
            } else { build_reg(m0_tail(decls), reg) }}}
        }
    }

    fn emit_c_type(reg : Int, t : Int) -> Int {
        let k : Int = m0_get(t, 0);
        if k == T_NAMED {
            let nm : String = m0_load_string(t, 3);
            if m0_string_eq(nm, "Int") == 1 { m0_print("int64_t") } else {
            if m0_string_eq(nm, "Float") == 1 { m0_print("double") } else {
            if m0_string_eq(nm, "String") == 1 { m0_print("char*") } else {
            if m0_string_eq(nm, "Bool") == 1 { m0_print("int") } else {
            if m0_string_eq(nm, "Char") == 1 { m0_print("char") } else {
            if m0_string_eq(nm, "Unit") == 1 { m0_print("void") } else {
            m0_print(nm)
            }}}}}}
        } else {
        if k == T_FN {
            emit_c_type(reg, m0_get(t, 5))
        } else {
            m0_print("int64_t")
        }}
    }

    fn emit_typedef_ef(reg : Int, l : Int) -> Int {
        if m0_is_nil(l) == 1 { 0 } else {
            let p0 : Int = emit_c_type(reg, m0_get(m0_head(l), 1));
            let p1 : Int = m0_print(" ");
            let p2 : Int = m0_print(m0_load_string(m0_head(l), 0));
            let p3 : Int = m0_print("; ");
            emit_typedef_ef(reg, m0_tail(l))
        }
    }

    fn emit_typedef_ec(reg : Int, l : Int) -> Int {
        if m0_is_nil(l) == 1 { 0 } else {
            let arg : Int = m0_get(m0_head(l), 1);
            let _ : Int = if arg != 0 {
                let p0 : Int = emit_c_type(reg, arg);
                let p1 : Int = m0_print(" ");
                let p2 : Int = m0_print(m0_load_string(m0_head(l), 0));
                let p3 : Int = m0_print("_v; ");
                p3
            } else { 0 };
            emit_typedef_ec(reg, m0_tail(l))
        }
    }

    fn emit_typedef(reg : Int, t : Int, name : String) -> Int {
        let k : Int = m0_get(t, 0);
        if k == T_RECORD {
            let p0 : Int = m0_print("typedef struct { ");
            let p1 : Int = emit_typedef_ef(reg, m0_get(t, 3));
            let p2 : Int = m0_print("} ");
            let p3 : Int = m0_print(name);
            m0_print(";\n")
        } else {
        if k == T_SUM {
            let p0 : Int = m0_print("typedef struct { int tag; union { ");
            let p1 : Int = emit_typedef_ec(reg, m0_get(t, 3));
            let p2 : Int = m0_print("} data; } ");
            let p3 : Int = m0_print(name);
            m0_print(";\n")
        } else { 0 }}
    }

    fn emit_c_op(op : Int) -> Int {
        if op == OP_ADD { m0_print("+") } else {
        if op == OP_SUB { m0_print("-") } else {
        if op == OP_MUL { m0_print("*") } else {
        if op == OP_DIV { m0_print("/") } else {
        if op == OP_MOD { m0_print("%") } else {
        if op == OP_EQ { m0_print("==") } else {
        if op == OP_NEQ { m0_print("!=") } else {
        if op == OP_LT { m0_print("<") } else {
        if op == OP_GT { m0_print(">") } else {
        if op == OP_LE { m0_print("<=") } else {
        if op == OP_GE { m0_print(">=") } else {
        if op == OP_AND { m0_print("&&") } else {
        if op == OP_OR { m0_print("||") } else {
        m0_print("?")
        }}}}}}}}}}}}}
    }

    fn emit_c_expr_ea(reg : Int, l : Int, first : Int) -> Int {
        if m0_is_nil(l) == 1 { 0 } else {
            let _p0 : Int = if first == 0 { m0_print(", ") } else { 0 };
            let _p1 : Int = emit_c_expr(reg, m0_head(l));
            emit_c_expr_ea(reg, m0_tail(l), 0)
        }
    }

    fn emit_arm_guard(reg : Int, pat : Int, body : Int) -> Int {
        let pk : Int = m0_get(pat, 0);
        if pk == P_LIT {
            let _p0 : Int = m0_print("else if (");
            let _p1 : Int = emit_c_expr(reg, m0_get(pat, 3));
            let _p2 : Int = m0_print(" == _m) { _result = (");
            let _p3 : Int = emit_c_expr(reg, body);
            m0_print("); }")
        } else {
        if pk == P_WILD {
            let _p0 : Int = m0_print("else { _result = (");
            let _p1 : Int = emit_c_expr(reg, body);
            m0_print("); }")
        } else {
        if pk == P_NAME {
            let nm : String = m0_load_string(pat, 3);
            let ctor : Int = lookup_ctor_info(reg, nm);
            if ctor == 0 {
                let _p0 : Int = m0_print("else { int64_t ");
                let _p1 : Int = m0_print(nm);
                let _p2 : Int = m0_print(" = _m; _result = (");
                let _p3 : Int = emit_c_expr(reg, body);
                m0_print("); }")
            } else {
                let sname : String = m0_load_string(ctor, 0);
                let _p0 : Int = m0_print("else if (_m.tag == ");
                let _p1 : Int = m0_print(sname);
                let _p2 : Int = m0_print("_");
                let _p3 : Int = m0_print(nm);
                let _p4 : Int = m0_print(") { _result = (");
                let _p5 : Int = emit_c_expr(reg, body);
                m0_print("); }")
            }
        } else {
        if pk == P_CTOR {
            let cname : String = m0_load_string(pat, 3);
            let ctor : Int = lookup_ctor_info(reg, cname);
            if ctor == 0 {
                let _p0 : Int = m0_print("else { _result = (");
                let _p1 : Int = emit_c_expr(reg, body);
                m0_print("); }")
            } else {
                let sname : String = m0_load_string(ctor, 0);
                let sub : Int = m0_get(pat, 4);
                let _p0 : Int = m0_print("else if (_m.tag == ");
                let _p1 : Int = m0_print(sname);
                let _p2 : Int = m0_print("_");
                let _p3 : Int = m0_print(cname);
                if m0_get(sub, 0) == P_NAME {
                    let _a0 : Int = m0_print(") { int64_t ");
                    let _a1 : Int = m0_print(m0_load_string(sub, 3));
                    let _a2 : Int = m0_print(" = _m.data.");
                    let _a3 : Int = m0_print(cname);
                    let _a4 : Int = m0_print("_v; _result = (");
                    let _a5 : Int = emit_c_expr(reg, body);
                    m0_print("); }")
                } else {
                    let _e0 : Int = m0_print(") { _result = (");
                    let _e1 : Int = emit_c_expr(reg, body);
                    m0_print("); }")
                }
            }
        } else {
            let _p0 : Int = m0_print("else { _result = (");
            let _p1 : Int = emit_c_expr(reg, body);
            m0_print("); }")
        }
        }
        }
        }
    }

    fn emit_c_expr_arms_ea(reg : Int, l : Int, first : Int) -> Int {
        if m0_is_nil(l) == 1 { 0 } else {
            let pat : Int = m0_get(m0_head(l), 0);
            let body : Int = m0_get(m0_head(l), 1);
            let _if0 : Int = if first == 1 { m0_print("if (0) {} ") } else { 0 };
            let _ag : Int = emit_arm_guard(reg, pat, body);
