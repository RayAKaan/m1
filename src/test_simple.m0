module Test {
    external "m0_char_at" : String -> Int -> Int
    external "m0_string_eq" : String -> String -> Int
    external "m0_string_len" : String -> Int
    external "m0_print" : String -> Int
    external "m0_print_int" : Int -> Int

    type M1Tk = | TkEof | TkInt | TkIdent | TkModule | TkType | TkFn | TkLet | TkMatch | TkIf | TkElse
               | TkTrue | TkFalse | TkExternal | TkNot | TkForall | TkExists
               | TkArrow | TkEq | TkEqEq | TkNeq | TkLt | TkGt | TkLe | TkGe
               | TkAnd | TkOr | TkPipe | TkColon | TkComma | TkSemi
               | TkLBrace | TkRBrace | TkLParen | TkRParen | TkLBrack | TkRBrack
               | TkPlus | TkMinus | TkStar | TkSlash | TkPercent | TkUnit

    fn and(a : Int, b : Int) -> Int {
        if a == 1 { if b == 1 { 1 } else { 0 } } else { 0 }
    }

    fn or(a : Int, b : Int) -> Int {
        if a == 1 { 1 } else { if b == 1 { 1 } else { 0 } }
    }

    fn is_alpha(c : Int) -> Int {
        if and(c >= 65, c <= 90) == 1 { 1 } else {
        if and(c >= 97, c <= 122) == 1 { 1 } else {
        if c == 95 { 1 } else { 0 }
        }}
    }

    fn keyword_or_ident(s : String, line : Int, col : Int) -> M1Token {
        0
    }
}
