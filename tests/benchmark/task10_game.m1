world GameTest {
    do main() -> Int {
        set Setup : Int = 0;
        set Playing : Int = 1;
        set Paused : Int = 2;
        set GameOver : Int = 3;

        set live state : Int = Setup;
        set live score : Int = 0;
        set _ : Int = now score >= 0;
        set _ : Int = when score >= 100 then { say("win") };
        set _ : Int = state = Playing;
        set _ : Int = say(int_to_string(was state.Playing));
        set _ : Int = score = 50;
        set _ : Int = score = 100;
        set _ : Int = state = GameOver;
        set _ : Int = say(int_to_string(was state.GameOver));
        set _ : Int = say(int_to_string(score));
        0
    }
}
