        let pk : Int = m0_get(pat, 0);
        if first == 0 {
        let p : Int = m0_print(" else ");
        } else {
    }
        if pk == P_WILD {
        let p0 : Int = m0_print("(");
        let p1 : Int = emit_c_expr(reg, body);
        let _s : Int = m0_print(")");
        } else {
        if pk == P_LIT {
        let p0 : Int = m0_print("(");
        let p1 : Int = emit_c_expr(reg, m0_get(pat, 3));
        let p2 : Int = m0_print(" == _m ? (");
        let p3 : Int = emit_c_expr(reg, body);
        m0_print(") : ")
        } else {
        if pk == P_NAME {
        let p0 : Int = m0_print("{ int64_t ")
        let p1 : Int = m0_print(m0_load_string(pat, 3));
        let p2 : Int = m0_print(" = _m; (");
        let p3 : Int = emit_c_expr(reg, body);
        m0_print("); }")
        } else {
        let p0 : Int = m0_print("(");
        let p1 : Int = emit_c_expr(reg, body);
        m0_print(")")
    }
    }
    }
        emit_c_expr_arms_ea(reg, m0_tail(l), 0)


