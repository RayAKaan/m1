    fn emit_c_op(op : Int) -> Int {
        if op == OP_ADD {
        m0_print("+")
        } else {
        if op == OP_SUB {
        m0_print("-")
        } else {
        if op == OP_MUL {
        m0_print("*")
        } else {
        if op == OP_DIV {
        m0_print("/")
        } else {
        if op == OP_MOD {
        m0_print("%")
        } else {
        if op == OP_EQ {
        m0_print("==")
        } else {
        if op == OP_NEQ {
        m0_print("!=")
        } else {
        if op == OP_LT {
        m0_print("<")
        } else {
        if op == OP_GT {
        m0_print(">")
        } else {
        if op == OP_LE {
        m0_print("<=")
        } else {
        if op == OP_GE {
        m0_print(">=")
        } else {
        if op == OP_AND {
        m0_print("&&")
        } else {
        if op == OP_OR {
        m0_print("||")
        } else {
        m0_print("?")
    }
    }
    }
    }
    }
    }
    }
    }
    }
    }
    }
    }


    fn emit_c_expr(reg : Int, e : Int) -> Int {
        let k : Int = m0_get(e, 0)
        if k == N_INT {
        m0_print_int(m0_get(e, 3))
        } else {
        if k == N_STRING {
        let p0 : Int = m0_print("\"")
        let p1 : Int = m0_print(m0_load_string(e, 3));
        m0_print("\"")
        } else {
        if k == N_BOOL {
        if m0_get(e, 3) == 1) {
        m0_print("1")
        } else {
        m0_print("0")
    }
        } else {
        if k == N_UNIT {
        m0_print("0")
        } else {
        if k == N_NAME {
        m0_print(m0_load_string(e, 3))
        } else {
        if k == N_BINARY {
        let p0 : Int = m0_print("(")
        let p1 : Int = emit_c_expr(reg, m0_get(e, 4));
        let p2 : Int = m0_print(" ");
        let p3 : Int = emit_c_op(m0_get(e, 3));
        let p4 : Int = m0_print(" ");
        let p5 : Int = emit_c_expr(reg, m0_get(e, 5));
        m0_print(")")
        } else {
        if k == N_NOT {
        let p0 : Int = m0_print("(!")
        let p1 : Int = emit_c_expr(reg, m0_get(e, 3));
        m0_print(")")
        } else {
        if k == N_FIELD {
        let p0 : Int = emit_c_expr(reg, m0_get(e, 3))
        let p1 : Int = m0_print(".");
        m0_print(m0_load_string(e, 4))
        } else {
        if k == N_CALL {
        let p0 : Int = emit_c_expr(reg, m0_get(e, 3))
        let p1 : Int = m0_print("(");
        let p2 : Int = emit_c_expr_ea(reg, m0_get(e, 4), 1);
        m0_print(")")
        } else {
        if k == N_LET {
        let p0 : Int = m0_print("({ ")
        let p1 : Int = emit_c_type(reg, m0_get(e, 4));
        let p2 : Int = m0_print(" ");
        let p3 : Int = m0_print(m0_load_string(e, 3));
        let p4 : Int = m0_print(" = ");
        let p5 : Int = emit_c_expr(reg, m0_get(e, 5));
        let p6 : Int = m0_print("; ");
        let p7 : Int = emit_c_expr(reg, m0_get(e, 6));
        m0_print("; })")
        } else {
        if k == N_IF {
        let p0 : Int = m0_print("(");
        let p1 : Int = emit_c_expr(reg, m0_get(e, 3));
        let p2 : Int = m0_print(" ? ");
        let p3 : Int = emit_c_expr(reg, m0_get(e, 4));
        let p4 : Int = m0_print(" : ");
        let el : Int = m0_get(e, 5);
        if el != 0 {
        let p5 : Int = emit_c_expr(reg, el);
        } else {
        let p5 : Int = m0_print("0");
    }
        m0_print(")")
        } else {
        if k == N_MATCH {
        let p0 : Int = m0_print("({ int64_t _m = ")
        let p1 : Int = emit_c_expr(reg, m0_get(e, 3));
        let p2 : Int = m0_print("; ");
        let p3 : Int = emit_c_expr_arms_ea(reg, m0_get(e, 4), 1);
        m0_print("; })")
        } else {
        if k == N_RECORD {
        let r2 : Int = lookup_reg(reg, m0_load_string(e, 3));
        let p0 : Int = m0_print("(");
        let p1 : Int = emit_c_type(reg, reg_type(r2));
        let p2 : Int = m0_print("){ ");
        let p3 : Int = emit_c_expr_ef(reg, m0_get(e, 3), 1);
        m0_print(" })")
        } else {
        m0_print("0")
    }
    }
    }
    }
    }
    }
    }
    }
    }
    }
    }
    }


