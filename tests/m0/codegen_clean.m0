        m0_print("%")
        } else {
        if
        (op == OP_EQ) {
        m0_print("==")
        } else {
        if
        (op == OP_NEQ) {
        m0_print("!=")
        } else {
        if
        (op == OP_LT) {
        m0_print("<")
        } else {
        if
        (op == OP_GT) {
        m0_print(">")
        } else {
        if
        (op == OP_LE) {
        m0_print("<=")
        } else {
        if
        (op == OP_GE) {
        m0_print(">=")
        } else {
        if
        (op == OP_AND) {
        m0_print("&&")
        } else {
        if
        (op == OP_OR) {
        m0_print("||")
        } else {
        m0_print("?")
    }
    }
