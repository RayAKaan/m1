        int64_t p =
        m0_get(t, 3);    (void)p;
        flatten_fn_params(m0_get(t, 5), m0_cons(m0_head(p), acc))
        } else {
        acc
        }}

    fn emit_extern(reg : Int, d : Int) -> Int {
        char *cn =
        m0_load_string(d, 3);  (void)cn;
        int64_t t =
        m0_get(d, 4);  (void)t;
        if
        (m0_get(t, 0) == T_FN) {
        int64_t ret =
        flatten_fn_ret(t);    (void)ret;
        int64_t params =
        rev(flatten_fn_params(t, m0_nil));    (void)params;
        emit_c_type(reg, ret);m0_print(" ");m0_print(cn);m0_print("(");emit_c_params(reg, params);return m0_print(");\n");
        } else {
        int64_t p0 =
        emit_c_type(reg, t);    (void)p0;
        int64_t p1 =
        m0_print(" ");    (void)p1;
        int64_t p2 =
        m0_print(cn);    (void)p2;
        m0_print(";\n")
        }}

    fn emit_fn(reg : Int, d : Int) -> Int {
        char *nm =
        m0_load_string(d, 3);  (void)nm;
