    fn emit_module(m : Int) -> Int {
        int64_t decls =
        m0_get(m, 4);  (void)decls;
        int64_t reg =
        build_reg(decls, m0_nil);  (void)reg;
        int64_t h =
        m0_print("#include <stdio.h>\n#include <stdint.h>\n\n");  (void)h;
