        (m0_is_nil(rest) == 0) {
        m0_print(", ");
        } else {
        0;
        }return emit_c_params(reg, rest);
        }}

    fn flatten_fn_ret(t : Int) -> Int {
        if
        (m0_get(t, 0) == T_FN) {
        flatten_fn_ret(m0_get(t, 5))
        } else {
        t
        }}

    fn flatten_fn_params(t : Int, acc : Int) -> Int {
        if
