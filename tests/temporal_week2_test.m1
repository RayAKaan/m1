-- Week 2 test for the new temporal parser + emit stubs in m1c.m0
-- Exercises all 6 temporal forms that should now parse with the updated m1c.m0.

module TestTemporalWeek2 {
    fn main() -> Int {
        -- freeze statement
        freeze bank;

        -- was expr
        set _ : Int = was bank.balance;

        -- will / now / when (expressions)
        set _ : Int = will order == 1;
        set _ : Int = now balance >= 0;
        when balance > 0 then { 1 };

        -- live declaration
        set live x : Int = 42;

        0
    }
}
