-- Week 2 test: all temporal forms that parse with the current m1c.m0.
module TestTemporal {
    do main() -> Int {
        -- live declaration
        set live x : Int = 42;
        set live y : Int = 0;

        -- freeze (via set wrapper)
        set _ : Int = freeze x;

        -- was expr (folds to compile-time literal)
        set _a : Int = was x.Live;

        -- will / now commitments
        set _b : Int = will y == 1;
        set _c : Int = now y >= 0;

        -- when/then (simple expression body, no braces)
        set _d : Int = when y > 0 then 1;

        0
    }
}
